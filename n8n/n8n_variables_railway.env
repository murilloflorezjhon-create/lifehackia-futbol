# ================================================================
#  LifeHackIA — Variables de entorno N8N en Railway
#  Agregar en: Railway → servicio n8n → Variables
# ================================================================

# ── AUTENTICACIÓN N8N ──────────────────────────────────────────
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=LifeHackIA2026!

# ── CONFIGURACIÓN DEL SERVIDOR ────────────────────────────────
N8N_HOST=0.0.0.0
N8N_PORT=5678
N8N_PROTOCOL=https
WEBHOOK_URL=https://TU-N8N-URL.up.railway.app   # ← reemplaza con tu URL real

# ── ZONA HORARIA ──────────────────────────────────────────────
GENERIC_TIMEZONE=America/Bogota
TZ=America/Bogota

# ── BASE DE DATOS ─────────────────────────────────────────────
DB_TYPE=sqlite
# (SQLite es suficiente para empezar — no necesitas configurar nada más)

# ── TU API FASTAPI (ya en Railway) ────────────────────────────
API_BASE=https://lifehackia-futbol-production.up.railway.app

# ── FOOTBALL DATA API ─────────────────────────────────────────
FOOTBALL_API_KEY=69a4800800db4cab9548fe84e5f35953

# ── TELEGRAM ──────────────────────────────────────────────────
# PASO 1: Crea un bot en @BotFather en Telegram
#   → /newbot → nombre: LifeHackIABot → usuario: LifeHackIA_bot
#   → Copia el TOKEN que te da BotFather
TELEGRAM_BOT_TOKEN=TU_TOKEN_DE_BOTFATHER

# PASO 2: Agrega el bot como administrador a tus canales
# PASO 3: Consigue los IDs de los canales:
#   → Envía un mensaje al canal → usa @userinfobot → copia el chat_id
#   → Los canales tienen IDs negativos, ej: -1001234567890
TELEGRAM_CANAL_GRATIS_ID=-1001234567890   # ← ID de @LifeHackIAPronosticos
TELEGRAM_CANAL_VIP_ID=-1009876543210      # ← ID del canal VIP privado

# ── GOOGLE SHEETS (para registro de suscriptores) ────────────
# PASO 1: Crea una hoja en Google Sheets con columnas:
#   Nombre | Email | Telefono | Fecha | Vencimiento | Plan | Estado | Referencia
# PASO 2: Comparte la hoja con la cuenta de servicio de N8N
# PASO 3: Copia el ID de la URL: docs.google.com/spreadsheets/d/[ESTE_ID]/edit
GOOGLE_SHEET_ID=TU_ID_DE_GOOGLE_SHEETS

# ================================================================
#  GUÍA PASO A PASO — INSTALAR N8N EN RAILWAY
# ================================================================
#
# 1. Ve a railway.app → tu proyecto gracious-dream
# 2. Clic "+ New Service" → "Docker Image"
# 3. Imagen: n8nio/n8n
# 4. Clic "Deploy"
# 5. Ve a la pestaña "Variables" y agrega todas las de arriba
# 6. Ve a "Settings" → "Networking" → "Generate Domain"
# 7. Copia la URL generada y ponla en WEBHOOK_URL
# 8. Espera 2-3 minutos a que Railway despliegue N8N
# 9. Abre la URL de N8N → login: admin / LifeHackIA2026!
# 10. Ve a Settings → Credentials → agrega el bot de Telegram
#
# IMPORTAR LOS WORKFLOWS:
# 1. En N8N → menú lateral → "Workflows"
# 2. Clic "Import from File"
# 3. Importa cada archivo JSON en este orden:
#    → n8n_workflow1_pronosticos.json
#    → n8n_workflow2_suscriptores.json
#    → n8n_workflow3_reporte.json
# 4. En cada workflow ajusta las credenciales de Telegram
# 5. Activa cada workflow con el toggle "Active"
#
# CREAR EL BOT DE TELEGRAM:
# 1. Abre Telegram → busca @BotFather
# 2. Envía /newbot
# 3. Nombre: LifeHackIA Picks Bot
# 4. Usuario: LifeHackIAPicks_bot (debe terminar en _bot)
# 5. Copia el TOKEN (formato: 123456789:ABCdef...)
# 6. Agrega el bot como ADMINISTRADOR en ambos canales
#
# WEBHOOK DE WOMPI (para Workflow 2):
# 1. En N8N → abre Workflow 2 → copia la URL del webhook
#    (formato: https://tu-n8n.up.railway.app/webhook/wompi-pago)
# 2. Ve a dashboard.wompi.co → Configuración → Webhooks
# 3. Agrega la URL copiada
# 4. Eventos: transaction.updated
# 5. Guarda
#
# ================================================================
